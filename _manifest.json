{
  "manifest_version": 2,
  "id": "com.0-hz.maibook",
  "version": "0.1.0",
  "name": "麦书 (MaiBook)",
  "description": "让麦麦在每个聊天中创作并长期维护属于自己的书：按聊天流隔离的「笔记本」内可建立多本书，每本书是一个目录（元信息 book.toml + 创作说明 instructions.md + 正文 manuscript/ + 隐藏设定 bible/ + 滚动摘要 summaries/ + 问答日志 journal/）。由一个可配置的「专职写手模型」生成正文（自动注入麦麦的人格与表达风格），麦麦本人担任主编；信息不足时不动笔，先把问题抛给麦麦自行决定（必要时再问用户）。支持按需写作与可选的后台自动续写、章节修订与历史快照、整书编译/分段发送/长图导出，以及把封面图直接送入上下文供共同打磨。",
  "author": {
    "name": "kes",
    "url": "https://github.com/yufei-pan"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/yufei-pan/maibook-plugin",
    "homepage": "https://github.com/yufei-pan/maibook-plugin",
    "documentation": "https://github.com/yufei-pan/maibook-plugin/blob/main/README.md",
    "issues": "https://github.com/yufei-pan/maibook-plugin/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.5.1",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "tomli",
      "version_spec": ">=2.0.0"
    },
    {
      "type": "python_package",
      "name": "tomli-w",
      "version_spec": ">=1.0.0"
    }
  ],
  "capabilities": [
    "config.get",
    "llm.generate",
    "send.text",
    "send.image",
    "render.html2png",
    "maisaka.context.append",
    "maisaka.proactive.trigger"
  ],
  "i18n": {
    "default_locale": "zh-CN"
  }
}
